#!/bin/bash
# vyos-postinstall — U-Boot boot helper for LS1046A Mono Gateway
#
# Two independent phases (each can succeed/fail without blocking the other):
#
#   Phase 1 — U-Boot SPI flash setup:
#     Writes vyos, usb_vyos, bootcmd to SPI NOR via fw_setenv.
#     Always runs (forced) when called from install image (--root flag).
#     Skips if already configured when called from the boot service (no --root).
#
#   Phase 2 — EVERY INSTALL/UPGRADE: Write /boot/vyos.env:
#     Tells U-Boot which image to load. Skipped gracefully if no
#     installed images exist (normal on USB live boot before install).
#
# Called automatically by vyos-postinstall.service on every boot.
# Also called by image_installer.py (install_image hook) and grub.py
# (set_default hook) after install/upgrade.
#
# Usage:
#   sudo vyos-postinstall                              # auto-detect root & image
#   sudo vyos-postinstall <image-name>                 # explicit image, auto root
#   sudo vyos-postinstall --root /mnt/wroot <image>    # explicit root & image
#
# The --root flag is critical when called from install_image(), where the
# eMMC target is mounted at a non-standard path (e.g., /mnt/wroot).
# Without --root, find_root() may not discover the mount point.
#
# This script is a no-op on non-LS1046A hardware.

VYOS_ENV_FILE="vyos.env"
FW_ENV_CONFIG="/etc/fw_env.config"
UBOOT_BOOTARGS_TAIL="console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 net.ifnames=0 boot=live rootdelay=5 noautologin fsl_dpaa_fman.fsl_fm_max_frm=9600 hugepagesz=2M hugepages=512 panic=60"

# Accumulated exit code — set to 1 on any actual error, but script always runs to completion
RC=0

# ─── Board detection ────────────────────────────────────────────────────────

check_board() {
    local compat="/proc/device-tree/compatible"
    if [ ! -f "$compat" ]; then
        echo "Not running on a DeviceTree platform. Skipping."
        exit 0
    fi
    if ! tr '\0' '\n' < "$compat" | grep -q "fsl,ls1046a"; then
        echo "Not an LS1046A board. Skipping."
        exit 0
    fi
}

# ─── Phase 1: U-Boot SPI flash setup ────────────────────────────────────────
#
# Writes static U-Boot variables to SPI NOR flash via fw_setenv:
#   vyos       — reads /boot/vyos.env → loads vmlinuz/dtb/initrd → booti
#   usb_vyos   — boot.scr delegation: USB FAT32 → boot script handles the rest
#   bootcmd    — USB first, then eMMC, then SPI recovery
#
# When called with force=1 (from install image via --root flag), ALWAYS writes
# SPI flash regardless of current state. This guarantees the boot order is
# correct after every install image run.
# When called without force (boot service, no --root), skips if already OK.

setup_uboot_env_once() {
    local force="${1:-0}"
    # Verify fw_setenv/fw_printenv tools exist
    if ! command -v fw_setenv >/dev/null 2>&1; then
        echo "WARNING: fw_setenv not found — cannot configure U-Boot SPI flash."
        echo "  Install libubootenv-tool or u-boot-tools package."
        RC=1
        return 1
    fi

    # Verify fw_env.config exists
    if [ ! -f "$FW_ENV_CONFIG" ]; then
        echo "WARNING: ${FW_ENV_CONFIG} not found — cannot access U-Boot env."
        RC=1
        return 1
    fi

    # Verify the MTD device exists (requires CONFIG_SPI_FSL_QSPI=y in kernel)
    local mtd_dev
    mtd_dev=$(awk '/^[^#]/ {print $1; exit}' "$FW_ENV_CONFIG")
    if [ -n "$mtd_dev" ] && [ ! -e "$mtd_dev" ]; then
        echo "WARNING: ${mtd_dev} does not exist — QSPI flash not accessible."
        echo "  Verify CONFIG_SPI_FSL_QSPI=y in kernel config."
        RC=1
        return 1
    fi

    # Test if fw_printenv can read the environment (validates config + flash access)
    if ! fw_printenv bootcmd >/dev/null 2>&1; then
        echo "WARNING: fw_printenv failed — cannot read U-Boot environment."
        echo "  This may mean fw_env.config offsets don't match the actual flash layout."
        echo "  Check /proc/mtd and compare with /etc/fw_env.config."
        echo ""
        echo "  Diagnostic info:"
        echo "  fw_env.config: $(cat "$FW_ENV_CONFIG" 2>/dev/null | grep -v '^#' | head -1)"
        if [ -f /proc/mtd ]; then
            echo "  /proc/mtd:"
            cat /proc/mtd | head -10
        fi
        RC=1
        return 1
    fi

    # Idempotency check — skip only when NOT forced (boot service path).
    # When force=1 (called from install image via --root), always rewrite SPI
    # to guarantee correct boot order after every install image run.
    if [ "$force" -eq 0 ]; then
        local current_vyos
        current_vyos=$(fw_printenv -n vyos 2>/dev/null || true)
        if echo "$current_vyos" | grep -q "vyos.env"; then
            echo "✓ U-Boot SPI flash already configured (vyos references vyos.env)."
            return 0
        fi
        echo "Configuring U-Boot SPI flash (first-time setup)..."
    else
        echo "Updating U-Boot SPI flash (forced by install image)..."
    fi

    # --- Define the U-Boot variables ---
    # Each variable value must work as a U-Boot hush command when run via 'run <var>'
    # No quotes around values — fw_setenv handles escaping.
    # initrd always loaded LAST so ${filesize} captures its size.

    # eMMC boot: read vyos.env → load kernel/dtb/initrd from per-image dir → booti
    local vyos_val
    vyos_val='ext4load mmc 0:3 ${load_addr} /boot/vyos.env; env import -t ${load_addr} ${filesize}; ext4load mmc 0:3 ${kernel_addr_r} /boot/${vyos_image}/vmlinuz; ext4load mmc 0:3 ${fdt_addr_r} /boot/${vyos_image}/mono-gw.dtb; ext4load mmc 0:3 ${ramdisk_addr_r} /boot/${vyos_image}/initrd.img; setenv bootargs BOOT_IMAGE=/boot/${vyos_image}/vmlinuz '"${UBOOT_BOOTARGS_TAIL}"' vyos-union=/boot/${vyos_image}; booti ${kernel_addr_r} ${ramdisk_addr_r}:${filesize} ${fdt_addr_r}'

    # USB live boot: delegate to boot.scr on the USB FAT32 filesystem.
    # boot.scr handles all file loading and bootargs — no hardcoded paths here.
    # Uses 'if fatload' so failure (no USB / no boot.scr) falls through
    # cleanly to the next || branch in bootcmd without executing 'source'
    # on garbage data at ${load_addr}.
    local usb_vyos_val
    usb_vyos_val='usb start; if fatload usb 0:0 ${load_addr} boot.scr; then source ${load_addr}; fi'

    # Boot priority: USB → eMMC → SPI recovery
    local bootcmd_val='run vyos || run recovery'

    # --- Write variables to SPI flash ---
    local failed=0

    echo "  Writing vyos..."
    if ! fw_setenv vyos "$vyos_val"; then
        echo "  ERROR: fw_setenv vyos failed"
        failed=1
    fi

    echo "  Writing usb_vyos..."
    if ! fw_setenv usb "$usb_vyos_val"; then
        echo "  ERROR: fw_setenv usb_vyos failed"
        failed=1
    fi

    echo "  Writing bootcmd..."
    if ! fw_setenv bootcmd "$bootcmd_val"; then
        echo "  ERROR: fw_setenv bootcmd failed"
        failed=1
    fi

    if [ "$failed" -eq 1 ]; then
        echo ""
        echo "ERROR: One or more fw_setenv calls failed."
        echo "  The U-Boot environment may be partially configured."
        echo "  You can fix this manually from the U-Boot serial console."
        echo "  See INSTALL.md Step 4 for the manual commands."
        RC=1
        return 1
    fi

    # Verify what we wrote
    echo ""
    echo "  Verifying..."
    local verify_vyos
    verify_vyos=$(fw_printenv -n vyos 2>/dev/null || true)
    if echo "$verify_vyos" | grep -q "vyos.env"; then
        echo "✓ U-Boot SPI flash configured successfully."
        echo "  bootcmd: $(fw_printenv -n bootcmd 2>/dev/null)"
        echo "  The board will now auto-boot from eMMC (or USB if inserted)."
    else
        echo "WARNING: Verification failed — vyos variable does not contain vyos.env."
        echo "  Manual U-Boot setup may be required (see INSTALL.md Step 4)."
        RC=1
    fi
}

# ─── Phase 2: Write /boot/vyos.env ──────────────────────────────────────────

# Find the persistence root (where /boot/<image-name>/ lives on eMMC).
# Returns empty string — not an error — if no installed images are found.
# This is normal during USB live boot before install image has been run.
find_root() {
    local candidate n

    for candidate in "/" "/mnt/root" "/mnt"; do
        if [ -d "${candidate}/boot" ]; then
            n=$(find "${candidate}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$n" -gt 0 ]; then
                echo "$candidate"
                return 0
            fi
        fi
    done

    # Scan all active mount points (catches /mnt/wroot used by install_image)
    while IFS= read -r mp; do
        [ -z "$mp" ] && continue
        if [ -d "${mp}/boot" ]; then
            n=$(find "${mp}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$n" -gt 0 ]; then
                echo "$mp"
                return 0
            fi
        fi
    done < <(mount | awk '{print $3}' | grep -v -E '^/(proc|sys|dev|run|snap)$')

    echo ""  # not found — caller handles this gracefully
}

detect_latest_image() {
    local root="$1"
    find "${root}/boot" -maxdepth 1 -mindepth 1 -type d -name '20*-*-rolling' \
        -printf '%f\n' 2>/dev/null | sort -r | head -1
}

# Determine image to boot — priority order:
#   1. Currently running image (from /proc/cmdline vyos-union= or BOOT_IMAGE=)
#   2. Existing vyos.env content (preserves user's set-default-boot choice)
#   3. Lexicographically latest (fallback for first install)
detect_current_image() {
    local root="$1"
    local img

    # 1. Currently running image from /proc/cmdline
    img=$(grep -oP '(?<=vyos-union=/boot/)[^ ]+' /proc/cmdline 2>/dev/null)
    if [ -n "$img" ] && [ -d "${root}/boot/${img}" ]; then
        echo "$img"
        return 0
    fi
    img=$(grep -oP '(?<=BOOT_IMAGE=/boot/)[^/]+' /proc/cmdline 2>/dev/null)
    if [ -n "$img" ] && [ -d "${root}/boot/${img}" ]; then
        echo "$img"
        return 0
    fi

    # 2. Existing vyos.env (preserves set-default-boot selection)
    local env_path="${root}/boot/${VYOS_ENV_FILE}"
    if [ -f "$env_path" ]; then
        img=$(grep -oP '(?<=vyos_image=)\S+' "$env_path" 2>/dev/null)
        if [ -n "$img" ] && [ -d "${root}/boot/${img}" ]; then
            echo "$img"
            return 0
        fi
    fi

    # 3. Fallback: lexicographically latest
    detect_latest_image "$root"
}

write_vyos_env() {
    local image_name="$1"
    local root="$2"
    local env_path="${root}/boot/${VYOS_ENV_FILE}"

    if printf 'vyos_image=%s\n' "$image_name" > "$env_path"; then
        echo "✓ Written: ${env_path} → vyos_image=${image_name}"
    else
        echo "ERROR: Cannot write ${env_path} — check permissions and mount state"
        RC=1
    fi
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    # Parse arguments: [--root <path>] [<image-name>]
    local explicit_root=""
    local image_name=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --root)
                shift
                explicit_root="${1:-}"
                shift
                ;;
            *)
                image_name="$1"
                shift
                ;;
        esac
    done

    check_board

    echo "=== VyOS Post-Install for LS1046A ==="

    # Phase 1: U-Boot SPI flash setup.
    # When --root is given (install image path): force=1 → always rewrites SPI
    # flash to guarantee correct boot order after every install image run.
    # When called from boot service (no --root): force=0 → skips if already OK.
    local force_spi=0
    [ -n "$explicit_root" ] && force_spi=1
    setup_uboot_env_once "$force_spi"

    # Phase 2: Write vyos.env.
    # If --root was given (e.g., from install_image), use it directly.
    # Otherwise auto-detect by scanning mount points.
    local root
    if [ -n "$explicit_root" ]; then
        root="$explicit_root"
        echo "Using explicit root: ${root}"
    else
        root=$(find_root)
    fi

    if [ -z "$root" ]; then
        echo ""
        echo "No installed VyOS images found — /boot/vyos.env write skipped."
        echo "(This is normal on USB live boot. Run 'install image' to install VyOS.)"
        exit $RC
    fi

    if [ -z "$image_name" ]; then
        image_name=$(detect_current_image "$root")
    fi

    if [ -z "$image_name" ]; then
        echo "WARNING: No VyOS image directories found under ${root}/boot/"
        exit $RC
    fi

    if [ ! -d "${root}/boot/${image_name}" ]; then
        echo "ERROR: Image directory '${root}/boot/${image_name}' does not exist"
        RC=1
        exit $RC
    fi

    echo "Image:  ${image_name}"
    echo "Root:   ${root}"
    echo ""
    write_vyos_env "$image_name" "$root"

    echo ""
    echo "=== Done ==="
    exit $RC
}

main "$@"
